{
  "name": "photofind",
  "version": "1.0.0",
  "description": "Scan and catalog photos with EXIF geolocation, metadata editing, and search.",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
